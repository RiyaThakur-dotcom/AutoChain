# Hardhat Deployment Configuration

# Sepolia RPC URL (Alchemy/Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer Wallet Private Key (Admin)
