# AutoChain Simulator Configuration

# Network RPC URL (e.g., Alchemy or Infura Sepolia Testnet)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Wallet Private Key (Vehicle Hardware Wallet)
# IMPORTANT: Use a testnet key with Sepolia ETH
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed Smart Contract Address
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# MongoDB URI (MongoDB Atlas or Local Instance)
MONGO_URI=mongodb+srv://admin:password@cluster0.abcde.mongodb.net/autochain?retryWrites=true&w=majority
